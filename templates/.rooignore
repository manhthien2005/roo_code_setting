# =============================================================================
# .rooignore — Filter noise from RooCode's context window
# =============================================================================
# Files/directories listed here are EXCLUDED from:
# - Workspace file listing (environment_details)
# - File search results
# - Context window population
#
# This reduces token waste and keeps AI focused on relevant code.
# =============================================================================

# --- Dependencies ---
node_modules/
.yarn/
.pnp.*
bower_components/

# --- Build outputs ---
dist/
build/
out/
.next/
.nuxt/
.output/
coverage/
*.tsbuildinfo

# --- Package manager locks (large, low-signal) ---
package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# --- Version control ---
.git/

# --- IDE/Editor ---
# Block most .vscode/ but allow key workflow files
# NOTE: .rooignore may not support negation patterns (!)
# If negation doesn't work, remove this block entirely
# and rely on .vscode/ files being low-noise enough
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.swp
*.swo
*~

# --- OS files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Environment & secrets ---
.env
.env.*
*.env
.env.local
.env.*.local
credentials.json
serviceAccountKey*.json
*.pem
*.key
*.p12
*.pfx
*.cert
*.crt
id_rsa*
*.keystore
secrets/
.secrets/
roo-settings.local.json

# --- Database dumps & sensitive logs ---
*.sql.gz
*.dump
*.bak

# --- Temporary / research repos (completed research) ---
temp-ecc/
temp-awesome-skills/

# --- Logs ---
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Binary / media assets (not useful for AI context) ---
*.png
*.jpg
*.jpeg
*.gif
*.ico
*.svg
*.woff
*.woff2
*.ttf
*.eot
*.mp3
*.mp4
*.webm
*.zip
*.tar.gz
*.rar

# --- Analysis artifacts (already processed) ---
roo-settings-analysis.md
roo-code-settings - Copy.json
